{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "ElasticConfiguration": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "catalog-api-logs-{0:yyyy.MM}"
  },
  "AllowedHosts": "*",
  "DatabaseSettings": {
    "ConnectionString": "mongodb://127.0.0.1:27017?readPreference=primary&&ssl=false",
    "DatabaseName": "CatalogDb",
    "BrandsCollection": "Brands",
    "TypesCollection": "Types",
    "ProductsCollection": "Products"
  },
  "Authentication": {
    "Authority": "http://localhost:8011",
    "Audience": "ecommerce_resource",
    "RequireHttpsMetadata": false
  },
  "GrpcSettings": {
    "DiscountUrl": "http://localhost:5002"
  }
}
